    "@mdx-js/react": "^3.1.1",
    "@playwright/test": "^1.58.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "gh-pages": "^6.3.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.3"
  }
